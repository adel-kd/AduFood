# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
JWT_SECRET=<generate-a-strong-random-secret>
Encryption_key=<generate-a-random-32-char-key>

# ──────────────────────────────────────────────
# URLs
# Change these in production to your actual deployed URLs
# ──────────────────────────────────────────────
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Chapa Payment Gateway
# Get keys at: https://dashboard.chapa.co
# Test keys start with CHAPUBK_TEST- / CHASECK_TEST-
# Live keys start with CHAPUBK-       / CHASECK-
# ──────────────────────────────────────────────
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-...
CHAPA_SECRET_KEY=CHASECK_TEST-...

# ──────────────────────────────────────────────
# IMPORTANT — Production Checklist
# ──────────────────────────────────────────────
# 1. Replace CHAPA_SECRET_KEY with your live key before going live
# 2. Set BACKEND_URL to your production domain (e.g. https://api.adufoods.com)
# 3. Set FRONTEND_URL to your production frontend (e.g. https://adufoods.com)
# 4. Set the Chapa webhook URL in your Chapa dashboard to:
#    https://<your-backend>/api/payment/webhook
# 5. Never commit real keys to git — .env is in .gitignore
